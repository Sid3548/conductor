{
  // User-editable agent registry.
  // Fields:
  // - name: tool identifier used by MCP methods
  // - mcp_name: Claude MCP server registration name
  // - mcp_cmd: command array used for `claude mcp add ... -- <cmd>`
  // - role: code | search | design | general
  // - description: routing/team description text
  // - detect_cmd: CLI binary checked via `command -v` (use this OR detect_path)
  // - detect_path: absolute file path checked via `test -f` (use this OR detect_cmd)
  "agents": [
    {
      "name": "codex",
      "mcp_name": "codex-delegate",
      "mcp_cmd": ["codex", "mcp-server"],
      "role": "code",
      "description": "Backend / engineering lead. Code, repo, files, debugging, tests, refactor, build.",
      "detect_cmd": "codex"
    },
    {
      "name": "gemini",
      "mcp_name": "gemini-delegate",
      "mcp_cmd_note": "requires shim at ~/.claude-router/gemini-mcp/server.mjs",
      "mcp_cmd": ["node", "~/.claude-router/gemini-mcp/server.mjs"],
      "role": "search",
      "description": "Search / UI / design lead. Web research, interfaces, visual design.",
      "detect_cmd": "gemini"
    },
    {
      "name": "qwen",
      "mcp_name": "qwen-delegate",
      "mcp_cmd_note": "requires llama-server running on port 8080 — use run-qwen27b-server.cmd",
      "mcp_cmd": ["node", "~/.claude-router/qwen-mcp/server.mjs"],
      "role": "general",
      "description": "Local offline reasoning. Privacy-sensitive tasks, quick drafts, no internet needed.",
      "detect_path": "/c/Users/user/AppData/Local/Microsoft/WinGet/Packages/ggml.llamacpp_Microsoft.Winget.Source_8wekyb3d8bbwe/llama-server.exe"
    }
  ]
}
